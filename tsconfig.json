{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,                                 
    "esModuleInterop": true,                        
    "skipLibCheck": true,                           
    "forceConsistentCasingInFileNames": true,     
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./lib/esm",
    "types": ["node"]
  }
}
